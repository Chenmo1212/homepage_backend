{
  "openapi": "3.0.0",
  "info": {
    "title": "Food Menu API",
    "description": "API for managing food menu dishes and orders",
    "version": "1.0.0",
    "contact": {
      "name": "API Support"
    }
  },
  "servers": [
    {
      "url": "http://localhost:5002",
      "description": "Development server"
    }
  ],
  "tags": [
    {
      "name": "Health",
      "description": "Health check endpoints"
    },
    {
      "name": "Dishes",
      "description": "Dish management endpoints"
    },
    {
      "name": "Orders",
      "description": "Order management endpoints"
    },
    {
      "name": "Statistics",
      "description": "Statistics endpoints"
    }
  ],
  "paths": {
    "/api/food-menu/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Health check",
        "description": "Check API and database connectivity",
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "healthy"
                    },
                    "database": {
                      "type": "string",
                      "example": "connected"
                    },
                    "service": {
                      "type": "string",
                      "example": "Food Menu API"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Service is unhealthy",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/food-menu/dishes": {
      "get": {
        "tags": ["Dishes"],
        "summary": "Get dishes list",
        "description": "Retrieve a list of dishes with optional filtering, sorting, and pagination",
        "parameters": [
          {
            "name": "category",
            "in": "query",
            "description": "Filter by category",
            "schema": {
              "type": "string",
              "enum": ["All", "Pork", "Chicken", "Seafood", "Vegetables"]
            }
          },
          {
            "name": "is_active",
            "in": "query",
            "description": "Filter by active status",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "sort_by",
            "in": "query",
            "description": "Sort field",
            "schema": {
              "type": "string",
              "enum": ["order_count", "price", "created_at"],
              "default": "order_count"
            }
          },
          {
            "name": "order",
            "in": "query",
            "description": "Sort direction",
            "schema": {
              "type": "string",
              "enum": ["asc", "desc"],
              "default": "desc"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of results",
            "schema": {
              "type": "integer",
              "default": 100
            }
          },
          {
            "name": "skip",
            "in": "query",
            "description": "Number of results to skip",
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Dish"
                      }
                    },
                    "total": {
                      "type": "integer"
                    },
                    "limit": {
                      "type": "integer"
                    },
                    "skip": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/food-menu/dishes/{dish_id}": {
      "get": {
        "tags": ["Dishes"],
        "summary": "Get dish by ID",
        "description": "Retrieve a single dish by its ID",
        "parameters": [
          {
            "name": "dish_id",
            "in": "path",
            "required": true,
            "description": "Dish ObjectId",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "$ref": "#/components/schemas/Dish"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Dish not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/food-menu/dishes/{dish_id}/stock": {
      "patch": {
        "tags": ["Dishes"],
        "summary": "Update dish stock",
        "description": "Update the stock quantity of a dish",
        "parameters": [
          {
            "name": "dish_id",
            "in": "path",
            "required": true,
            "description": "Dish ObjectId",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "quantity": {
                    "type": "integer",
                    "description": "Quantity to add (positive) or subtract (negative)",
                    "example": 10
                  }
                },
                "required": ["quantity"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Stock updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "$ref": "#/components/schemas/Dish"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Dish not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/food-menu/dishes/popular": {
      "get": {
        "tags": ["Dishes"],
        "summary": "Get popular dishes",
        "description": "Retrieve popular dishes sorted by order count",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of results",
            "schema": {
              "type": "integer",
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Dish"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/food-menu/dishes/search": {
      "get": {
        "tags": ["Dishes"],
        "summary": "Search dishes",
        "description": "Search dishes by keyword",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "Search keyword",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Dish"
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Missing search keyword",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/food-menu/orders": {
      "post": {
        "tags": ["Orders"],
        "summary": "Create order",
        "description": "Create a new food order",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateOrderRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Order created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "$ref": "#/components/schemas/Order"
                    },
                    "order_number": {
                      "type": "string",
                      "example": "ORD202412251230001234"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Dish not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": ["Orders"],
        "summary": "Get orders list",
        "description": "Retrieve a list of orders with optional filtering",
        "parameters": [
          {
            "name": "customer_email",
            "in": "query",
            "description": "Filter by customer email",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "Filter by order status",
            "schema": {
              "type": "string",
              "enum": ["pending", "confirmed", "preparing", "ready", "delivered", "completed", "cancelled"]
            }
          },
          {
            "name": "delivery_date",
            "in": "query",
            "description": "Filter by delivery date",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of results",
            "schema": {
              "type": "integer",
              "default": 50
            }
          },
          {
            "name": "skip",
            "in": "query",
            "description": "Number of results to skip",
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Order"
                      }
                    },
                    "total": {
                      "type": "integer"
                    },
                    "limit": {
                      "type": "integer"
                    },
                    "skip": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/food-menu/orders/{order_number}": {
      "get": {
        "tags": ["Orders"],
        "summary": "Get order details",
        "description": "Retrieve order details with items",
        "parameters": [
          {
            "name": "order_number",
            "in": "path",
            "required": true,
            "description": "Order number",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "$ref": "#/components/schemas/OrderWithItems"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Order not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Orders"],
        "summary": "Cancel order",
        "description": "Cancel an order and restore stock",
        "parameters": [
          {
            "name": "order_number",
            "in": "path",
            "required": true,
            "description": "Order number",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Order cancelled successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "message": {
                      "type": "string",
                      "example": "Order cancelled successfully"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Order not found or cannot be cancelled",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/food-menu/orders/{order_number}/status": {
      "patch": {
        "tags": ["Orders"],
        "summary": "Update order status",
        "description": "Update the status of an order",
        "parameters": [
          {
            "name": "order_number",
            "in": "path",
            "required": true,
            "description": "Order number",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": {
                    "type": "string",
                    "enum": ["pending", "confirmed", "preparing", "ready", "delivered", "completed", "cancelled"],
                    "example": "confirmed"
                  }
                },
                "required": ["status"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Status updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "$ref": "#/components/schemas/Order"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Order not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/food-menu/stats/dishes": {
      "get": {
        "tags": ["Statistics"],
        "summary": "Get dish statistics",
        "description": "Retrieve statistics about dishes",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "$ref": "#/components/schemas/DishStats"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/food-menu/stats/orders": {
      "get": {
        "tags": ["Statistics"],
        "summary": "Get order statistics",
        "description": "Retrieve statistics about orders",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "$ref": "#/components/schemas/OrderStats"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Dish": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string",
            "description": "MongoDB ObjectId"
          },
          "name": {
            "type": "string",
            "example": "宫保鸡丁"
          },
          "name_en": {
            "type": "string",
            "example": "Kung Pao Chicken"
          },
          "price": {
            "type": "number",
            "format": "float",
            "example": 12.99
          },
          "stock": {
            "type": "integer",
            "example": 50
          },
          "order_count": {
            "type": "integer",
            "example": 10
          },
          "category": {
            "type": "string",
            "enum": ["Pork", "Chicken", "Seafood", "Vegetables"],
            "example": "Chicken"
          },
          "image_url": {
            "type": "string",
            "example": "https://example.com/dish.jpg"
          },
          "description": {
            "type": "string",
            "example": "经典川菜"
          },
          "description_en": {
            "type": "string",
            "example": "Classic Sichuan dish"
          },
          "ingredients": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": ["鸡肉", "花生", "辣椒"]
          },
          "ingredients_en": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": ["Chicken", "Peanuts", "Chili"]
          },
          "nutrition": {
            "type": "object",
            "properties": {
              "calories": {
                "type": "integer"
              },
              "protein": {
                "type": "integer"
              }
            }
          },
          "is_active": {
            "type": "boolean",
            "example": true
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateOrderRequest": {
        "type": "object",
        "required": ["delivery_date", "delivery_time", "items"],
        "properties": {
          "customer_name": {
            "type": "string",
            "example": "John Doe"
          },
          "customer_email": {
            "type": "string",
            "format": "email",
            "example": "john@example.com"
          },
          "customer_phone": {
            "type": "string",
            "example": "1234567890"
          },
          "delivery_date": {
            "type": "string",
            "format": "date",
            "example": "2024-12-25"
          },
          "delivery_time": {
            "type": "string",
            "example": "12:00-13:00"
          },
          "delivery_address": {
            "type": "string",
            "example": "123 Main St"
          },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "dish_id": {
                  "type": "string",
                  "description": "Dish ObjectId"
                },
                "quantity": {
                  "type": "integer",
                  "minimum": 1,
                  "example": 2
                }
              },
              "required": ["dish_id", "quantity"]
            }
          },
          "payment_method": {
            "type": "string",
            "example": "cash"
          },
          "notes": {
            "type": "string",
            "example": "No spicy please"
          }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string"
          },
          "order_number": {
            "type": "string",
            "example": "ORD202412251230001234"
          },
          "customer_name": {
            "type": "string"
          },
          "customer_email": {
            "type": "string"
          },
          "customer_phone": {
            "type": "string"
          },
          "delivery_date": {
            "type": "string",
            "format": "date"
          },
          "delivery_time": {
            "type": "string"
          },
          "delivery_address": {
            "type": "string"
          },
          "total_amount": {
            "type": "number",
            "format": "float"
          },
          "total_items": {
            "type": "integer"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "confirmed", "preparing", "ready", "delivered", "completed", "cancelled"]
          },
          "payment_status": {
            "type": "string",
            "enum": ["unpaid", "paid"]
          },
          "payment_method": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "OrderWithItems": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Order"
          },
          {
            "type": "object",
            "properties": {
              "items": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "dish_id": {
                      "type": "string"
                    },
                    "dish_name": {
                      "type": "string"
                    },
                    "dish_name_en": {
                      "type": "string"
                    },
                    "price": {
                      "type": "number"
                    },
                    "quantity": {
                      "type": "integer"
                    },
                    "subtotal": {
                      "type": "number"
                    },
                    "dish": {
                      "$ref": "#/components/schemas/Dish"
                    }
                  }
                }
              }
            }
          }
        ]
      },
      "DishStats": {
        "type": "object",
        "properties": {
          "total_dishes": {
            "type": "integer"
          },
          "total_stock": {
            "type": "integer"
          },
          "by_category": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "_id": {
                  "type": "string",
                  "description": "Category name"
                },
                "count": {
                  "type": "integer"
                },
                "avg_price": {
                  "type": "number"
                },
                "total_stock": {
                  "type": "integer"
                },
                "total_orders": {
                  "type": "integer"
                }
              }
            }
          }
        }
      },
      "OrderStats": {
        "type": "object",
        "properties": {
          "total_orders": {
            "type": "integer"
          },
          "total_revenue": {
            "type": "number",
            "format": "float"
          },
          "by_status": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "_id": {
                  "type": "string",
                  "description": "Status name"
                },
                "count": {
                  "type": "integer"
                },
                "total_amount": {
                  "type": "number"
                }
              }
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "error": {
